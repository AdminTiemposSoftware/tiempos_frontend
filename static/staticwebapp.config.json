{
	"navigationFallback": {
		"rewrite": "/index.html",
		"exclude": [
			"/_app/*",
			"/_app/immutable/*",
			"/_app/immutable/assets/*",
			"/_app/immutable/chunks/*",
			"/_app/immutable/entry/*",
			"/_app/immutable/nodes/*",
			"/_app/env.js",
			"/_app/version.json",
			"/favicon.*",
			"/robots.txt"
		]
	}
}
